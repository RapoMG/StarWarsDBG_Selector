<NewCampaignWindow>
    name: "new_campaign"
    on_pre_enter: root.on_pre_enter()


    TempBackground:

    FloatLayout: # window main container

        BoxLayout: # details container
            orientation: "vertical"
            size_hint: (1, 0.85)
            pos_hint: {"center_x": 0.5, "center_y": 0.572}
            canvas.before:
                Color:
                    rgba: (0.33, 1, 0.73, 0.812)
                Line:
                    rounded_rectangle:
                        self.x, self.y, self.width, self.height, 10

            TempLabel:
                color: "black"
                text: "game number 1/5"
                pos_hint: {"center_y":.9, "center_x":0.5}

            GridLayout: # player faction container
                rows: 1
                cols: 2
                size_hint: (1, 0.2)
                orientation: "tb-lr" # top-bottom, left-right/ Use here to display cards vertically (better readability)

                # Player 1
                Button:
                    id: faction1
                    color: "black"
                    text: "Select faction"
                    on_release: root.chose_faction(0)

                # Player 2
                Button:
                    id: faction2
                    text: "Select faction"
                    color: "black"
                    on_release: root.chose_faction(1)

            TempLabel:
                color: "black"
                text: "Leader"
                pos_hint: {"center_y":.9, "center_x":0.5}

            GridLayout: # player name container
                rows: 1
                cols: 2
                size_hint: (1, 0.2)
                orientation: "tb-lr"

                TempLabel:
                    id: player1
                    color: "black"
                    text: "player1 name"

                TempLabel:
                    id: player2
                    color: "black"
                    text: "player2 name"

            TempLabel:
                color: "black"
                text: "Reinforcements"
                pos_hint: {"center_y":.9, "center_x":0.5}

            GridLayout: # player reinforcements container
                rows: 1
                cols: 2
                size_hint: (1, 0.2)
                orientation: "tb-lr"

                Button: # expansion faction hidden if same as default faction (for both players)
                    id: exp_faction1
                    color: "black"
                    text: "Reinforcements"
                    on_release: root.chose_reinforcements(0)

                Button: # expansion faction hidden if same as default faction (for both players)
                    id: exp_faction2
                    color: "black"
                    text: "Reinforcements"
                    on_release: root.chose_reinforcements(0)

            TempLabel:
                id: rules_warning
                color: "red"
                bold: True
                text: "Warning! The selected sets do not comply with the official rules of the game."
                opacity: 0

            TempButton:
                id: start
                text: "Start campaign>>"
                pos_hint: {"center_x": 0.5, "center_y": 1}
                size_hint: (0.6, 0.2)
                opacity: 0
                on_release:
                    root.start_campaign()
                    app.root.current = "campaign_details"

        # Previous window button
        Back:
            text: "<<campaigns_list"
            on_release:
                root.clean_fields()
                app.root.current = "campaigns_list"

