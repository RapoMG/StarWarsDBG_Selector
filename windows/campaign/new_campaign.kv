<NewCampaignWindow>
    name: "new_campaign"
    on_pre_enter: root.on_pre_enter()


    WallBackground: # Background:

    FloatLayout: # window main container

        BoxLayout: # details container
            orientation: "vertical"
            size_hint: (1, 0.85)
            pos_hint: {"center_x": 0.5, "center_y": 0.572}

            # Title
            Label:
                color: (1, 1, 0, 0.96)
                text: "New Campaign"
                font_name: "SW"
                font_size: min(Window.width, Window.height) * 0.07
                pos_hint: {"center_y":.9, "center_x":0.5}
                size_hint_x: 1
                size_hint_y: None
                height: self.texture_size[1]

                # Panel background variant
                color: (1, .81, 0, 0.86)
                bold: True
                outline_width: 1
                outline_color: (0.59, .27, 0.81, 0.812)

            # Players factions container
            GridLayout:
                rows: 1
                cols: 2
                size_hint: (1, 0.2)
                orientation: "tb-lr" # top-bottom, left-right/ Use here to display cards vertically (better readability)

                # Player 1
                FactionBtn:
                    id: faction1
                    on_release: root.chose_faction(0)

                # Player 2
                FactionBtn:
                    id: faction2
                    on_release: root.chose_faction(1)

            # Leaders header
            Label:
                color: "black"
                text: "Leaders"
                font_size: min(Window.width, Window.height) * 0.046
                font_name: "Results"
                color: (0.59, .27, 0.81, 0.812)
                pos_hint: {"center_y":.9, "center_x":0.5}
                outline_width: 1
                outline_color: (1, 1, 1, 0.5)
                size_hint_x: 1
                size_hint_y: None
                height: self.texture_size[1]

            # Players names container
            GridLayout:
                rows: 1
                cols: 2
                size_hint: (1, 0.2)
                size_hint_y: None # allows dynamic height and correct scrolling
                height: self.minimum_height
                orientation: "tb-lr"

                Label:
                    id: player1
                    font_size: root.height * 0.038 if len(self.text) <= 13 else (root.height * 0.034)
                    font_name: "Holo"
                    color: (0.33, 1, 0.68, 0.812)
                    text: "player1 name"
                    size_hint_x: 1
                    size_hint_y: None
                    height: self.texture_size[1]

                Label:
                    id: player2
                    font_size: root.height * 0.038 if len(self.text) <= 10 else (root.height * 0.028)
                    font_name: "Holo"
                    color: (0.33, 1, 0.68, 0.812)
                    text: "player2 name"
                    size_hint_x: 1
                    size_hint_y: None
                    height: self.texture_size[1]

            # Reinforcements label
            Label:
                text: "Reinforcements"
                font_size: min(Window.width, Window.height) * 0.046
                font_name: "Results"
                color: (0.59, .27, 0.81, 0.812)
                pos_hint: {"center_y":.9, "center_x":0.5}
                outline_width: 1
                outline_color: (1, 1, 1, 0.5)
                size_hint_x: 1
                size_hint_y: None
                height: self.texture_size[1]
                padding: 0, dp(15),0,0

            GridLayout: # player reinforcements container
                rows: 1
                cols: 2
                size_hint: (1, 0.2)
                orientation: "tb-lr"

                FactionBtn: # expansion faction hidden if same as default faction (for both players)
                    id: exp_faction1
                    on_release: root.chose_reinforcements(0)

                FactionBtn: # expansion faction hidden if same as default faction (for both players)
                    id: exp_faction2
                    on_release: root.chose_reinforcements(1)

            Label:
                id: rules_warning
                color: "red"

                text: "Warning! The selected sets do not comply with the official rules of the game."
                opacity: 0
                font_size: min(Window.width, Window.height) * 0.028
                font_name: "Results"
#                color: (0.59, .27, 0.81, 0.812)
                multiline: True
                pos_hint: {"center_y":.9, "center_x":0.5}
                outline_width: 2
                outline_color: (1, 1, 1, 0.5)
                size_hint_y: None # allows dynamic height and correct scrolling
                #height: self.minimum_height
                halign: "center"
                valign: "middle"
                height: self.texture_size[1]

                text_size: self.width - dp(20), None
                padding: dp(10), dp(10)

            Next:
            #TempButton:
                id: start
                text: "Give orders to attack!"
                #pos_hint: {"center_x": 0.5, "center_y": 1}
                #size_hint: (0.6, 0.2)
                opacity: 0
                on_release:
                    root.start_campaign()
                    root.clean_fields()


        # Previous window button
        Back:
            text: "That is unacceptable!"
            on_release:
                root.clean_fields()
                root.clean_app()
                app.root.current = "campaigns_list"



