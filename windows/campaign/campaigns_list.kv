<CampaignsListWindow>
    name: "campaigns_list"

    Background:

    FloatLayout:

        Button:
            size_hint: (0.45,0.06)
            #pos_hint: {"center_y":.5, "center_x":0.5}
            text: "New Entry"
            pos_hint: {"center_y":.95, "center_x":0.5}
            color: (0.59, .27, 0.81, 0.812)
            font_name: "SW"#"Results"
            bold: True
            background_color: (0, 0, 0, 0)
            outline_color: (1, 1, 1, 0.8)
            outline_width: 1
            on_release:
                app.root.current = "new_campaign"

            canvas.before:
                Color:
                    rgba: .2, .2, .2, 0.0
                RoundedRectangle:
                    pos: self.pos
                    size: self.size

                Color:
                    rgba: (0.59, .27, 0.81, 0.812)  # Purple

                Line:
                    rounded_rectangle:
                        self.x, self.y, self.width, self.height, 10
                    width: 5

            canvas:
                Color:
                    rgba: (1, 1, 1, 0.7)
                Line:
                    rounded_rectangle:
                        self.x, self.y, self.width, self.height, 10
                    width: 2

        ScrollView:
            do_scroll_x: True
            size_hint: (1, 0.7)
            pos_hint: {"center_x": 0.5, "center_y": 0.52}

            GridLayout:
                id: campaigns
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(20)
                padding: dp(20)


        # Previous window button
        Back:
            text: "Leave!"
            on_release:
                app.clear_working_elements()
                app.root.current = "welcome"


<CampaignButton>
    id: campaign_id
    size_hint_y: 1
    size_hint_x: 0.8# None
    #height: Window.height * 0.15#dp(120)


    canvas.before:
        Color:
            rgba: .2, .2, .2, 0.7
        RoundedRectangle:
            pos: self.pos
            size: self.size

        Color:
            rgba: (0.33, 1, 0.73, 0.612)  # Green
            #rgba: (1, 1, 0, 0.612)  # Yellow
        Line:
            rounded_rectangle:
                self.x, self.y, self.width, self.height, 20
            width: 4

    canvas:
        Color:
            rgba: (1, 1, 1, 0.8)
        Line:
            rounded_rectangle:
                self.x, self.y, self.width, self.height, 20
            width: 2
# Battle
    Label:
        id: battle_label
        text: f"{root.game} battle"
        font_size: root.height * 0.17#min(Window.width, Window.height) * 0.045 #"22sp"
        font_name: "SW"
        #color: (0.33, 1, 0.73, 0.812)
        #pos_hint: {"x": 0.05, "top": 1}
        size_hint: .5, .2
#        top: self.parent.top - dp(35)
#        center_x: root.center_x
        pos_hint: {"center_x": 0.5, "top": .95}

        outline_width: 0.5
        outline_color: (1, 1, 0, 0.5)

    # Player 1 name
    Label:
        id: p1_name_label
        text: root.p1_name
        font_size: root.height * 0.18 if len(self.text) <= 13 else (root.height * 0.14)
        font_name: "Holo"
        color: (0.33, 1, 0.73, 0.812)

        size_hint: None, None
        text_size: self.width, None

        width: battle_label.center_x - campaign_id.x - dp(7)
        height: root.height * 0.2

        right: battle_label.center_x - dp(5)
        top: battle_label.y - (dp(2) if len(self.text) <= 13 else dp(3))

        halign: "right"
        valign: "middle"

    # Player 1 reinforcements
    Label:
        id: p1_reinforcements_label
        text: root.p1_reinforcements
        font_size: min(Window.width, Window.height) * 0.038
        font_name: "Results"
        color: (0.59, .27, 0.81, 0.812)
        size_hint: None, None
        size: self.texture_size

        x: p1_faction_image.center_x - dp(45)
        top: p1_faction_image.y - dp(2)


    # Player 1 faction image
    Image:
        id: p1_faction_image
        source: root.p1_faction_image
        size_hint: None, None
        size:  root.width * .41, root.height * 0.25

        x: campaign_id.x + dp(1)
        top: p1_name_label.y - dp(2)
        fit_mode: "scale-down"

    Label:
        id: p2_name_label
        text: root.p2_name
        font_size: root.height * 0.18 if len(self.text) <= 13 else (root.height * 0.14)
        font_name: "Holo"
        color: (0.33, 1, 0.68, 0.812)

        size_hint: None, None

        x: battle_label.center_x + dp(15)
        top: battle_label.y - (dp(2) if len(self.text) <= 14 else dp(3))

        width: campaign_id.right - self.x - dp(2)
        height: root.height * 0.2

        text_size: self.width, None

        halign: "left"
        valign: "middle"

    # Player 2 faction image
    Image:
        id: p2_faction_image
        source: root.p2_faction_image
        size_hint: None, None
        size:  root.width * .41, root.height * 0.25
        #size: min(Window.width, Window.height) * 0.3, min(Window.width, Window.height) * 0.3
        #pos_hint: {"right": 0.989, "y": 0.115}
        fit_mode: "scale-down"
        right: campaign_id.right - dp(1)
        top: p1_name_label.y - dp(2)
        fit_mode: "scale-down"

    # Player 2 reinforcements
    Label:
        id: p2_reinforcements_label
        text: root.p2_reinforcements
        font_size: min(Window.width, Window.height) * 0.038
        font_name: "Results"
        color: (0.59, .27, 0.81, 0.812)
        size_hint: None, None
        size: self.texture_size

        right: p2_faction_image.center_x + dp(45)
        top: p2_faction_image.y - dp(2)

<DeleteBtn>
    size_hint: (.1, .5)

    background_normal:''
    background_down:''
    background_color: (0, 0, 0, 0)
#
#    canvas.after:
#        Color:
#            rgba: (1, 1, 0, 0.812)
#        Line:
#            rounded_rectangle:
#                self.x, self.y, self.width, self.height, 10
    Image:
        source: 'nav_buttons/del.png'
        pos: root.pos
        size: root.size
        fit_mode: "contain"
        color: (1, 1, 1, 1) if root.state == 'normal' else (0.7, 0.7, 0.7, 1)