<CampaignsListWindow>
    name: "campaigns_list"
#    on_pre_enter:
#        root.on_pre_enter()  # load campaigns

    TempBackground:

    FloatLayout:

        TempButton:
            text: "New Campaign >> "
            pos_hint: {"center_y":.95, "center_x":0.5}
            on_release:
                app.root.current = "new_campaign"

        ScrollView:
            do_scroll_x: True
            size_hint: (1, 0.9)
            pos_hint: {"center_x": 0.5, "center_y": 0.4}
#            canvas.before:
#                Color:
#                    rgba: (0.33, 1, 0.73, 0.812)
#                Line:
#                    rounded_rectangle:
#                        self.x, self.y, self.width, self.height, 10

            GridLayout:
                id: campaigns
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(20)
                padding: dp(20)


        # Previous window button
        Back:
            text: "<< welcome window"
            on_release:
                app.root.current = "welcome"


<CampaignButton>
    size_hint_y: None
    height: dp(120)

    canvas.before:
        Color:
            rgba: .2, .2, .2, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size

    Label:
        text: f"{root.game} battle"
        font_size: "22sp"
        pos_hint: {"x": 0.05, "top": 1}

    Label:
        text: root.p1_name
        font_size: "22sp"
        size_hint: None, None
        size: self.texture_size
        pos_hint: {"right": 0.6, "top": 0.9}

    Label:
        text: root.p1_faction
        font_size: "30sp"
        size_hint: None, None
        size: self.texture_size
        pos_hint: {"X": 1, "top": 1}

    Label:
        text: root.p1_reinforcements
        font_size: "16sp"
        size_hint: None, None
        size: self.texture_size
        pos_hint: {"right": 1, "top": 1}


    Label:
        text: root.p2_name
        font_size: "22sp"
        pos_hint: {"x": 0.05, "top": 0.5}

    Label:
        text: root.p2_faction
        font_size: "30sp"
        size_hint: None, None
        size: self.texture_size
        pos_hint: {"X": 0, "y": 0}

    Label:
        text: root.p2_reinforcements
        font_size: "16sp"
        pos_hint: {"right": 0, "y": 1}
