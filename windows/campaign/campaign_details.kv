<CampaignDetailsWindow>
    name: "campaign_details"

    Background:

    FloatLayout: # window main container

        BoxLayout: # details container
            orientation: "vertical"
            size_hint: (1, 0.82)
            pos_hint: {"center_x": 0.5, "center_y": 0.581}

            HeaderLabel:
                color: (1, 1, 0, 0.96)
                text: f"[b]{root.game_number}[/b] game setup"
                pos_hint: {"center_y":.9, "center_x":0.5}
                markup: True
                font_name: "SW"
                font_size: min(Window.width, Window.height) * 0.04
                outline_width: 0

            # Player names and factions
            GridLayout: # player faction container
                rows: 2
                cols: 2
                size_hint: (1, 0.2)
                size_hint_y: None # allows dynamic height and correct scrolling
                height: self.minimum_height

#               Text variant for a faction field
#                HeaderLabel:
#                    id: faction1
#                    text: "Faction 1"
#                    font_size: min(Window.width, Window.height) * 0.038
#
#                Label:
#                    id: faction2
#                    text: "Faction 2"
#                    font_size: min(Window.width, Window.height) * 0.038

                Image:
                    id: faction1
                    source: 'nav_buttons/quest.png'
                    size_hint_y: None
                    height: self.texture_size[1]
                    padding: dp(5)

                Image:
                    id: faction2
                    source: 'nav_buttons/quest.png'
                    size_hint_y: None
                    height: self.texture_size[1]
                    padding: dp(5)

                PlayerLabel:
                    id: player1
                    text: "player1"
                    font_size: root.height * 0.034 if len(self.text) <= 13 else (root.height * 0.026)


                PlayerLabel:
                    id: player2
                    text: "player2"
                    font_size: root.height * 0.034 if len(self.text) <= 13 else (root.height * 0.026)


            HeaderLabel:
                text: "Reinforcements"
                color: (1, .81, 0, 0.812)
                outline_color: (0, 0, 0, 0.5)

            # reinforcements factions
            GridLayout:
                rows: 1
                cols: 2
                size_hint: (1, 0.2)
                size_hint_y: None # allows dynamic height and correct scrolling
                height: self.minimum_height

                HeaderLabel: # expansion faction hidden if same as default faction (for both players)
                    id: rein1
                    text: "Expansion_Faction 1"
                    font_size: min(Window.width, Window.height) * 0.038


                HeaderLabel: # expansion faction hidden if same as default faction (for both players)
                    id: rein2
                    text: "Expansion_Faction 2"
                    font_size: min(Window.width, Window.height) * 0.038

            # Warning about extraordinary alliance
            HeaderLabel:
                id: rules_warning
                text: "You won’t find any mention of this extraordinary alliance in the official archives."
                opacity: 0

                color: "red"
                font_size: min(Window.width, Window.height) * 0.035
                multiline: True

                outline_width: 2
                halign: "center"
                valign: "middle"
                text_size: self.width - dp(20), None


            # Starter cards header with columns
            GridLayout:
                rows: 1
                cols: 5
                size_hint: (1, 0.08)

                # header
                PlayerLabel:
                    text: "Card name"
                    font_size: root.height * 0.022
                    font_name: "Holo_Ex"

                PlayerLabel:
                    text: "#"
                    font_size: root.height * 0.022
                    font_name: "Holo_Ex"

                    size_hint_x: 0.35
                    width: dp(60)

                PlayerLabel:
                    text: "Card name"
                    font_size: root.height * 0.022
                    font_name: "Holo_Ex"

                PlayerLabel:
                    text: "#"
                    font_size: root.height * 0.022
                    font_name: "Holo_Ex"

                    size_hint_x: 0.35
                    width: dp(60)

            # Cards container with scrollview to allow dynamic number of cards
            ScrollView:
                do_scroll_x: False
                do_scroll_y: True

                # All cards container
                GridLayout:
                    cols: 1
                    rows: 5
                    size_hint_y: None # allows dynamic height and correct scrolling
                    height: self.minimum_height
                    spacing: dp(20)

                    # Starter cards container
                    EditableArea:
                        id: starter_cards_area
                        action: "starter cards"
                        owner: root
                        rows:2

                        canvas.before:
                            Color:
                                rgba: (0, 0.39, 1, 0.812) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 3
                        canvas:
                            Color:
                                rgba: (1, 1, 1, 0.612) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 1

                        # Starter cards and removed/added cards
                        HeaderLabel: # Stater cards header
                            text: "Starter cards"
                            #font_size: min(Window.width, Window.height) * 0.028
                            padding: 0

                        # Starter cards rows
                        GridLayout:
                            id: starter_cards
                            cols: 1 # rows are dynamic with length of starter cards list
                            size_hint_y: None # allows dynamic height and correct scrolling
                            height: self.minimum_height

                    # Removed cards container
                    EditableArea:
                        id: removed_cards_area
                        owner: root
                        action: "removed cards"

                        canvas.before:
                            Color:
                                rgba: (0.33, 1, 0.73, 0.812) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 3
                        canvas:
                            Color:
                                rgba: (1, 1, 1, 0.612) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 1

                        HeaderLabel: # Removed cards header
                            text: "Galaxy deck removed cards"
                            #font_size: min(Window.width, Window.height) * 0.028
                            padding: 0

                        # Galaxy deck removed cards
                        GridLayout:
                            id: removed_cards
                            cols: 1 # rows are dynamic with length of starter cards list
                            size_hint_y: None # allows dynamic height and correct scrolling
                            height: self.minimum_height

                    # added cards container
                    EditableArea:
                        id: added_cards_area
                        owner: root
                        action: "added cards"

                        canvas.before:
                            Color:
                                rgba: (0.33, 0.5, 0.5, 0.812) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 3
                        canvas:
                            Color:
                                rgba: (1, 1, 1, 0.612) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 1

                        HeaderLabel: # Added cards header
                            text: "Added cards"
                            #font_size: min(Window.width, Window.height) * 0.028
                            padding: 0

                        # Galaxy deck removed cards
                        GridLayout:
                            id: added_cards
                            cols: 1 # rows are dynamic with length of starter cards list
                            size_hint_y: None # allows dynamic height and correct scrolling
                            height: self.minimum_height

                    # Removed bases container
                    EditableArea:
                        id: removed_bases_area
                        owner: root
                        action: "removed bases"

                        canvas.before:
                            Color:
                                rgba: (1, 1, 0, 0.812) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 3

                        canvas:
                            Color:
                                rgba: (1, 1, 1, 0.612) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 1

                        HeaderLabel: # Removed bases header
                            text: "Removed Bases"
                            #font_size: min(Window.width, Window.height) * 0.028
                            padding: 0

                        # Removed Bases
                        GridLayout:
                            id: removed_bases
                            cols: 1 # rows are dynamic with length of starter cards list
                            size_hint_y: None # allows dynamic height and correct scrolling
                            height: self.minimum_height

#########################################################################
                    # Starting bases container
                    EditableArea:
                        id: starting_bases_area
                        owner: root
                        action: "starting base"

                        canvas.before:
                            Color:
                                rgba: (0, 1, 0.4, 0.812) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 3

                        canvas:
                            Color:
                                rgba: (1, 1, 1, 0.612) if self.editable else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10
                                width: 1

                        HeaderLabel: # Starting bases header
                            text: "Starting Bases"
                            #font_size: min(Window.width, Window.height) * 0.028
                            padding: 0

                        # Starting Bases
                        GridLayout:
                            id: starting_bases
                            cols: 1 # rows are dynamic with length of starter cards list
                            size_hint_y: None # allows dynamic height and correct scrolling
                            height: self.minimum_height


            # Force tracker
            GridLayout:
                id: force_tracker
                rows: 1
                cols: 7
                size_hint: (0.9, 0.28)
                pos_hint: {"center_x": 0.5}

                ForceField:
                    id: p1_resource
                ForceField:
                    id: force_2
                ForceField:
                    id: force_3
                ForceField:
                    id: force_n
                ForceField:
                    id: force_5
                ForceField:
                    id: force_6
                ForceField:
                    id: p2_resource

            #Buttons
            Button:
                id: main_button
                text: root.main_button_text
                opacity: 1
                pos_hint: {"center_x": 0.5, "center_y": 1}

                color: (1, .81, 0, 0.812)
                font_name: "Holo"

                size_hint: (.55, 0.15)
                background_color: (0,0,0,0.45)

                # Border around button
                canvas.before:
                    Color:
                        rgba: (1, .81, 0, 0.812)
                    Line:
                        rounded_rectangle:
                            self.x, self.y, self.width, self.height, 10
                on_release:
                    root.primary_action()

        # Previous window button
        Back:
            text: "That's enough... for now. "
            on_release:
                root.exit_cleanup()
                app.root.current = "campaigns_list"


##### Definitions of dynamic rows for starter cards, removed cards, and added cards ###
<StarterDeckRow>
    size_hint_y: None
    height: self.minimum_height
    cols: 4

    CardLine:
        text: root.p1_card_name

    CardLine:
        text: root.p1_card_nbr
        size_hint_x: 0.35
        width: dp(60)

    CardLine:
        text: root.p2_card_name

    CardLine:
        text: root.p2_card_nbr
        size_hint_x: 0.35
        width: dp(60)

<ForceField@ToggleButton>
    size_hint: (0.1, 0.75)
    pos_hint: {"center_y": 0.5}
    background_normal: ""
    background_down: ""
    background_color: (0, 0, 0, 0)

    disabled: True

    group: "force_field"
    canvas.before:
        Color:
            rgba:(0.49,0.49,0.49,.5)
        Rectangle:
            size: dp(48), dp(48)
            pos:
                self.center_x - self.width * 0.39, \
                root.center_y - dp(27)

    canvas.after:
        Color:
            rgba:(1,1,0.35,1) if self.state == "down" else (0,0,0,0)
        Rectangle:
            source: "chk_buttons/force.png" if self.state == "down" else ""
            size: dp(48), dp(48)
            pos:
                self.center_x - self.width * 0.39, \
                root.center_y - dp(27)
    on_press:
        if self.state == "normal": self.state = "down"

<EditableArea>
    owner: root
    action: ""
    size_hint_y: None
    height: self.minimum_height
    cols: 1
    rows:2

<PlayerLabel@Label>
    # Text
    bold: True
    font_name: "Holo"
    color: (0.33, 1, 0.68, 0.812)
    outline_width: 1
    outline_color: (0, 0, 0, 0.5)

    # Area
    size_hint_x: 1
    size_hint_y: None
    height: self.texture_size[1]

<HeaderLabel@Label>
    font_size: min(Window.width, Window.height) * 0.040
    font_name: "Results"

    color: (0.59, .27, 0.81, 0.812)
    outline_width: 1
    outline_color: (1, 1, 1, 0.5)

    pos_hint: {"center_y":.9, "center_x":0.5}
    size_hint_x: 1
    size_hint_y: None
    height: self.texture_size[1]
    padding: dp(5)

<CardLine@Label>
    font_size: min(Window.width, Window.height) * 0.04
    font_name: "Holo"
    color: (1, .81, 0, 0.812)
    bold: True

    outline_width: 1
    outline_color: (0, 0, 0, 0.5)

    size_hint_x: 1
    size_hint_y: None
    height: self.texture_size[1]


