<AddCardTablePopup>:

    title_size: 0  # no title line
    separator_height:0 # no separator line

    auto_dismiss: False # auto_dismiss set to True to allow user to dismiss popup
    size_hint: (0.9, 0.9)

    background: 'images/backgrounds/panel.png'


    FloatLayout:

        # Title
        Label:
            size_hint: (1, 0.3)
            pos_hint: {"center_y":.9, "center_x":0.5}

            text: root.action
            font_name: "Holo"
            color: (0.33, 1, 0.73, 0.812)
            font_size: min(Window.width, Window.height) * 0.07
            bold: True

        # Faction 1 name
        Faction:
            text: root.faction1
            pos_hint: {"x":0.14, "center_y":.73}

        # Text input 1
        Player_name:
            id: faction1_card
            pos_hint: {"center_y":.64, "center_x":0.5}
            hint_text: "card to add"
            text: ""
            size_hint_x: .75

        # Faction 2 name
        Faction:
            text: root.faction2
            pos_hint: {"right":0.88, "center_y":.53}

        # Text input 2
        Player_name:
            id: faction2_card
            pos_hint: {"center_y":.42, "center_x":0.5}
            hint_text: "card to add"
            text: ""
            size_hint_x: .75

        # Save card names
        Button:
            text: "Confirm"
            color: (0.33, 1, 0.73, 0.812)
            font_name: "Holo"
            pos_hint: {"center_y":.2, "center_x":0.5}
            size_hint: (.45, 0.09)
            background_color: (0,0,0,0)

            # Border around button
            canvas.before:
                Color:
                    rgba: (0.33, 1, 0.73, 0.812)
                Line:
                    rounded_rectangle:
                        self.x, self.y, self.width, self.height, 10

            on_release:
                root.dismiss()

<Faction@Label>
    size_hint: None, None
    size: self.texture_size
    font_name: "Holo"
    color: (0.33, 1, 0.73, 0.812)
    font_size: min(Window.width, Window.height) * 0.06