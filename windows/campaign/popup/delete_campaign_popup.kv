<DeleteCampaignPopup>


    separator_height:0 # no separator line
    title: "_Delete Campaign_"
    title_font: "Holo"
    title_color: (0.33, 1, 0.73, 0.812)
    title_align: "center"
    title_size: dp(26)

    auto_dismiss: True # auto_dismiss set to True to allow user to dismiss popup
    size_hint: (0.8, 0.4)

    background: 'images/backgrounds/fog.png'

    BoxLayout:
        orientation: "vertical"
        padding: dp(10)
        spacing: dp(10)

        Label:
            text: "Hello there!\nArchives may become incomplete.\nAre you sure you want to delete this campaign?"
            multiline: True
            color: (0.33, 1, 0.73, 0.812)
            font_name: "Holo"
            font_size: min(Window.width, Window.height) * 0.045

            halign: "center"
            valign: "middle"
            text_size: self.width - dp(20), None


        BoxLayout:
            size_hint_y: None
            spacing: dp(10)
            height: dp(50)

            Option:
                text: "YES"
                id: yes_btn

            Option:
                text: "NO"
                id: no_btn

<Option@Button>
    background_normal:''
    background_down:''
    background_color: (0, 0, 0, 0)

    color: (0.33, 1, 0.73, 0.812)
    font_name: "Holo"
    bold: True
    font_size: min(Window.width, Window.height) * 0.07

    canvas.before:
        Color:
            rgba: (0.33, 1, 0.73, 0.812)
        Line:
            rounded_rectangle:
                self.x, self.y, self.width, self.height, 10






