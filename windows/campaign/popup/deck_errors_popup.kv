<DeckErrorsPopup>
    title_size: 0  # no title line
    separator_height:0 # no separator line

    auto_dismiss: False # auto_dismiss set to True to allow user to dismiss popup
    size_hint: (0.9, 0.9)

    background: 'images/backgrounds/panel.png'

    FloatLayout:

        GridLayout:
            id: errors_grid
            cols: 1
            size_hint_y: None
            pos_hint: {'center_x':0.5, 'center_y':0.8}
            height: self.minimum_height
            spacing: dp(4)
            padding: (dp(20), 0, dp(18), 0)


        Button:
            text: "Acknowledge"#'Return'
            color: (1, .1, 0, 0.812) #(0.33, 1, 0.73, 0.812)
            font_name: "Holo"
            font_size: min(Window.width, Window.height) * 0.07

            size_hint: (0.5, 0.10)
            pos_hint :{'center_x':0.5, 'center_y':0.048}
            background_normal: 'images/nav_buttons/tab_fog_med.png'
            background_down: 'images/nav_buttons/tab_fog_dark.png'


            canvas.after:
                # Normal
                Color:
                    rgba: (1, .1, 0, 0.812) if self.state == 'normal' else (0,0,0,0)
                Line:
                    points:
                        (self.x, self.top,
                        self.x, self.y,
                        self.right, self.y,
                        self.right, self.top)
                    width: 1

                # Down
                Color:
                    rgba: (1, .1, 0, 0.812) if self.state == 'down' else (0,0,0,0)
                Line:
                    points:
                        (self.x, self.top,
                        self.x, self.y,
                        self.right, self.y,
                        self.right, self.top,
                        )
                    width: 4

            on_release:

                root.dismiss()

<Errors>
    font_size: min(Window.width, Window.height) * 0.04
    font_name: "Holo"
    color: (1, .1, 0, 0.812)
    multiline: True

    outline_width: 1
    outline_color: (0, 0, 0, 0.5)

    text_size: self.width - dp(20), None
    halign: "center"
