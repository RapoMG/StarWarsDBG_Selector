<SelectFactionPopup>

    #title_size: 0  # no title line
    separator_height:0 # no separator line
    title: "_Select Faction_"
    title_font: "Holo"
    title_color: (0.33, 1, 0.73, 0.812)
    title_align: "center"
    title_size: dp(26)

    auto_dismiss: True # auto_dismiss set to True to allow user to dismiss popup
    size_hint: (0.9, 0.45)

    background: 'images/backgrounds/fog.png'

    GridLayout:
        cols: 1
        rows: 5

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            FactionBtn:
                id: field1
                size_hint: (0.5,0.5)
                on_release:
                    root.assign_faction(root.field1)

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            FactionBtn:
                id: field2
                size_hint: (0.5,0.5)
                on_release:
                    root.assign_faction(root.field2)

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            opacity: 0 if root.field3 == "" else 1

            FactionBtn:
                id: field3
                size_hint: (0.5,0.5)
                on_release:
                    root.assign_faction(root.field3)


        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            opacity: 0 if root.field4 == "" else 1

            FactionBtn:
                id: field4
                size_hint: (0.5,0.5)
                on_release:
                    root.assign_faction(root.field4)

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            opacity: 0 if root.field5 == "" else 1

            FactionBtn:
                id: field5
                size_hint: (0.5,0.5)
                on_release:
                    root.assign_faction(root.field5)
