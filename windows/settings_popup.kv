<InfoPopup>

    title_size: 0  # no title line
    separator_height:0 # no separator line

    auto_dismiss: False # auto_dismiss set to True to allow user to dismiss popup
    size_hint: (0.9, 0.9)

    background: 'images/backgrounds/panel.png'


    FloatLayout:
        TabbedPanel:
            do_default_tab: False  # prevent default tab
            pos_hint: {"center_y":.56, "center_x":0.5}
            size_hint: (0.99, 0.9)
            tab_pos: 'top_mid'
            background_image: 'images/backgrounds/fog.png'


            PopPanel:
                text: "Players"

                # Layout inside tab Players
                FloatLayout:

                    Label:
                        size_hint: (1, 0.3)
                        pos_hint: {"center_y":.9, "center_x":0.5}

                        text: "_Leaders names_"
                        font_name: "Holo"
                        color: (0.33, 1, 0.73, 0.812)
                        font_size: min(Window.width, Window.height) * 0.075
                        bold: True

                    Player_name:
                        id: pl1_name
                        pos_hint: {"center_y":.75, "center_x":0.45}
                        hint_text: "Player 1" # max 16 char
                        text: root.player1_name

                    Player_name:
                        id: pl2_name
                        pos_hint: {"center_y":.64, "center_x":0.5}
                        hint_text: "Player 2"
                        text: root.player2_name

                    Player_name:
                        id: pl3_name
                        pos_hint: {"center_y":.53, "center_x":0.55}
                        hint_text: "Player 3"
                        text: root.player3_name

                    Player_name:
                        id: pl4_name
                        pos_hint: {"center_y":.42, "center_x":0.5}
                        hint_text: "Player 4"
                        text: root.player4_name

                    # Save players names
                    Button:
                        text: "Confirm"
                        color: (0.33, 1, 0.73, 0.812)
                        font_name: "Holo"
                        pos_hint: {"center_y":.2, "center_x":0.5}
                        size_hint: (.45, 0.09)
                        background_color: (0,0,0,0)

                        # Border around button
                        canvas.before:
                            Color:
                                rgba: (0.33, 1, 0.73, 0.812)
                            Line:
                                rounded_rectangle:
                                    self.x, self.y, self.width, self.height, 10

                        on_release:
                            root.update()
                            root.dismiss()

            PopPanel:
                text: "Cards"

                ScrollView:
                    do_scroll_x: False

                    GridLayout:
                        rows: 15
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(10)

                        Label:
                            size_hint: (1, None)

                            text: "_Assign code names_"
                            font_name: "Holo"
                            color: (0.33, 1, 0.73, 0.812)
                            font_size: min(Window.width, Window.height) * 0.075
                            bold: True

                        SectionLabel:
                            text: f"Rebelion"

                        CardGrid:
                            id: reb_layout

                        SectionLabel:
                            text: "Reinforcements"
                            font_size: min(Window.width, Window.height) * 0.055

                        CardGrid:
                            id: reb_re_layout
                            padding: [self.width * 0.30, 0, self.width * 0.15, 0]

                        SectionLabel:
                            text: "Empire"

                        CardGrid:
                            id: imp_layout

                        SectionLabel:
                            text: "Reinforcements"
                            font_size: min(Window.width, Window.height) * 0.055

                        CardGrid:
                            id: imp_re_layout
                            padding: [self.width * 0.30, 0, self.width * 0.15, 0]

                        SectionLabel:
                            text: "Republic"

                        CardGrid:
                            id: pub_layout

                        SectionLabel:
                            text: "Separatists"

                        CardGrid:
                            id: sep_layout

                        SectionLabel:
                            text: "Mandalorian"

                        CardGrid:
                            id: mando_layout

            PopPanel:
                text: "About"

                ScrollView:
                    do_scroll_x: False

                    Label:
                        markup: True
                        font_name: "Holo"
                        font_size: min(Window.width, Window.height) * 0.045
                        size_hint: (0.99, 0.9)
                        color: (0.33, 1, 0.73, 0.812)
                        text: root.about

                        # text alignment
                        halign: "left"
                        valign: "top"
                        size_hint_y: None
                        height: self.texture_size[1]

                        text_size: self.width - dp(20), None
                        padding: dp(10), dp(10)
                        # Link to github
                        on_ref_press: root.link_to_github(args[1])

        Button:
            text: 'Return'
            color: (0.33, 1, 0.73, 0.812)
            font_name: "Holo"
            font_size: min(Window.width, Window.height) * 0.07

            size_hint: (0.5, 0.10)
            pos_hint :{'center_x':0.5, 'center_y':0.048}
            background_normal: 'images/nav_buttons/tab_fog_med.png'
            background_down: 'images/nav_buttons/tab_fog_dark.png'


            canvas.after:
                # Normal
                Color:
                    rgba: (0.33, 1, 0.73, 0.812) if self.state == 'normal' else (0,0,0,0)
                Line:
                    points:
                        (self.x, self.top,
                        self.x, self.y,
                        self.right, self.y,
                        self.right, self.top)
                    width: 1

                # Down
                Color:
                    rgba: (0.33, 1, 0.73, 0.812) if self.state == 'down' else (0,0,0,0)
                Line:
                    points:
                        (self.x, self.top,
                        self.x, self.y,
                        self.right, self.y,
                        self.right, self.top,
                        )
                    width: 4

            on_release: root.dismiss()

<SectionLabel@Label>
    font_name: "Holo"
    color: (0.33, 1, 0.73, 0.812)
    font_size: min(Window.width, Window.height) * 0.065
    bold: True

    size_hint_y: None
    height: self.texture_size[1]

<CardGrid@GridLayout>
    cols: 1
    size_hint_y: None
    height: self.minimum_height
    spacing: dp(15)
    padding: [self.width * 0.15, 0, self.width * 0.30, 0]

<CardRenameBase>
    font_size: root.height * 0.60
    font_name: "Holo_Ex"
    halign: "left"
    valign: "middle"
    multiline: False

    size_hint_y: None
    height: root.minimum_height
    foreground_color: (0.33, 1, 0.73, 0.812)

    border_margin: (0,4,0,4)
    background_color: (0,0,0,0)

<CardRename>
    canvas.before:
        Color:
            rgba: 0.33, 1, 0.73, 0.812

        Line:
            points: self.x, self.y, self.x, self.top
            width: 1

        Line:
            points: self.x, self.y, self.right, self.y
            width: 1

<CardRenameRight>
    halign: "right"

    canvas.before:
        Color:
            rgba: 0.33, 1, 0.73, 0.812

        Line:
            points: self.right, self.y, self.right, self.top
            width: 1

        Line:
            points: self.x, self.y, self.right, self.y
            width: 1