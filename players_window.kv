<PlayersWindow>
    name: "p_number"

    FloatLayout:
        #Call Background object
        Background:

        Label:
            text: "players"
            pos_hint: {"center_y":.7, "center_x":0.59}  #pos_hint: {"center_y":.7, "center_x":0.38} 56
            font_size: min(Window.width, Window.height) * 0.07
            outline_color: (0.855, 0.361, 1)
            outline_width: 2

        Label:
            id: n_players
            text: root.nbr_plyrs
            font_size: min(Window.width, Window.height) * 0.07
            bold: True
            outline_color: (0.855, 0.361, 1)
            outline_width: 2
            pos_hint: {"center_y":.7, "center_x":0.27}  #pos_hint: {"center_y":.7, "center_x":0.73} 22

        Button:
            #text: "+"
            bold: True
            background_normal: 'up_dim.png'
            background_down: 'up_light.png'
            pos_hint: {"center_y":.77, "center_x":0.27}  #pos_hint: {"center_y":.77, "center_x":0.73}
            on_press: root.incr()

        Button:
            #text: "-"
            bold: True
            background_normal: 'down_dim.png'
            background_down: 'down_light.png'
            pos_hint: {"center_y":.63, "center_x":0.27}  #pos_hint: {"center_y":.63, "center_x":0.73}
            on_press: root.decr()

        Next:
            text: "That is... acceptable"

            on_release:
                app.root.current = "factions"
                root.players()

