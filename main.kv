#:import NoTransition kivy.uix.screenmanager.NoTransition
#:import Window kivy.core.window.Window
#:include players_window.kv
#:include faction_window.kv
#:include draw_result_window.kv


ScreenManager:
    transition: NoTransition()
    LoadingWindow:
    PlayersWindow:
    FactionsWindow:
    DrawResultsWindow:

### Definitions ###
# Labels
<Summary@Label>
    color: (0.812, 0.796, 0.043)

    outline_color: (0, 0, 0)
    outline_width: 2

    halign:"center"
    valign:"middle"

<Set@Label>
    font_size: min(Window.width, Window.height) * 0.03
    outline_color: (0, 0, 0)
    outline_width: 2
    color: (1,1,1,1)
    size_hint_y: 0.2

#Background settings
<Background@Widget>
    size: root.width, root.height
    orientation: "horizontal"
    spacing: 10

    canvas:
        Rectangle:
            source:'images/background.png'
            size: root.width, root.height
            pos: self.pos

#Buttons
<Button>
    font_size: min(Window.width, Window.height) * 0.04
    size_hint: (0.29,0.12)

<Faction_switch@ToggleButton>
    size_hint: (0.45,0.06)

<Next@Button>
    color: (0,0,0,1)
    font_size: min(Window.width, Window.height) * 0.03
    italic: True
    bold: True

    #background_color: (1,1,1,1)
    background_normal: 'nav_buttons/bubble_right.png'
    background_down: 'nav_buttons/bubble_right_press.png'

    pos_hint :{'center_x':0.5, 'center_y':0.25}
    size_hint: .62, .18  #.50, .058


<Back@Button>
    color: (0,0,0,1)
    font_size: min(Window.width, Window.height) * 0.03
    italic: True
    bold: True

    background_color: (1,1,1,1)
    background_normal: 'nav_buttons/bubble_left.png'
    background_down: 'nav_buttons/bubble_left_press.png'

    pos_hint :{'center_x':0.5, 'center_y':0.1}
    size_hint: .55, .16

#Windows
<LoadingWindow>:
    name: "loading"

    FloatLayout:
        canvas.before:
            Color:
                rgba: (0.12, 0.12, 0.12, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Loading..."
            color: (0.92, 0.92, 0.92, 1)
            font_size: 28
            bold: True
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
